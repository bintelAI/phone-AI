<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.M3t.History.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/m3t_history_icon_padding"
    app:cardBackgroundColor="@color/m3t_dialog_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/m3t_about_row_text_gap">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="GhProxy"
                android:textAppearance="@style/TextAppearance.M3t.Title.Medium" />

            <TextView
                android:id="@+id/tvUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/m3t_spacing_xs"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="https://..."
                android:textAppearance="@style/TextAppearance.M3t.Body.Small" />

        </LinearLayout>

        <ImageView
            android:id="@+id/btnCopy"
            android:layout_width="@dimen/m3t_history_close_button_size"
            android:layout_height="@dimen/m3t_history_close_button_size"
            android:layout_marginStart="@dimen/m3t_spacing_sm"
            android:background="@drawable/bg_circle_light"
            android:padding="@dimen/m3t_spacing_sm"
            android:src="@drawable/ic_content_copy_24"
            app:tint="@color/m3t_on_surface_variant" />

        <ImageView
            android:id="@+id/btnOpen"
            android:layout_width="@dimen/m3t_history_close_button_size"
            android:layout_height="@dimen/m3t_history_close_button_size"
            android:layout_marginStart="@dimen/m3t_spacing_sm"
            android:background="@drawable/bg_circle_light"
            android:padding="@dimen/m3t_spacing_sm"
            android:src="@drawable/ic_arrow_right"
            app:tint="@color/m3t_on_surface_variant" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
