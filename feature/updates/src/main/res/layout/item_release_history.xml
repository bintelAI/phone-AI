<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/m3t_spacing_sm"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/m3t_surface"
    app:cardCornerRadius="@dimen/m3t_radius_lg"
    app:cardElevation="0dp"
    app:strokeColor="@color/m3t_outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/m3t_spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.M3t.Title.Medium"
                android:textColor="@color/m3t_on_surface" />

            <TextView
                android:id="@+id/tvPrerelease"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_prerelease_chip"
                android:paddingHorizontal="@dimen/m3t_update_chip_padding_h"
                android:paddingVertical="@dimen/m3t_update_chip_padding_v"
                android:text="@string/m3t_updates_prerelease"
                android:textAppearance="@style/TextAppearance.M3t.Body.Small"
                android:textColor="@color/m3t_on_primary"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/m3t_spacing_xs"
            android:textAppearance="@style/TextAppearance.M3t.Body.Medium"
            android:textColor="@color/m3t_on_surface" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/m3t_spacing_xxxs"
            android:textAppearance="@style/TextAppearance.M3t.Body.Small"
            android:textColor="@color/m3t_on_surface_variant" />

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/m3t_spacing_sm"
            android:maxLines="2"
            android:ellipsize="end"
            android:textAppearance="@style/TextAppearance.M3t.Body.Small"
            android:textColor="@color/m3t_on_surface_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/m3t_spacing_sm"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpen"
                style="@style/Widget.M3t.Button.Tonal.Dialog.Compact"
                android:layout_width="0dp"
                android:layout_height="@dimen/m3t_compact_button_height"
                android:layout_weight="1"
                android:text="@string/m3t_updates_view"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDownload"
                style="@style/Widget.M3t.Button.Filled"
                android:layout_width="0dp"
                android:layout_height="@dimen/m3t_compact_button_height"
                android:layout_marginStart="@dimen/m3t_spacing_sm"
                android:layout_weight="1"
                android:text="@string/m3t_updates_download"
                android:textAllCaps="false" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
