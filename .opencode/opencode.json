{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "alibaba-coding-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Alibaba Coding Plan",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/v1",
        "apiKey": "{env:ALIBABA_CODING_PLAN_API_KEY}"
      },
      "models": {
        "qwen3.5-plus": {
          "name": "Qwen3.5 Plus",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "glm-5": {
          "name": "GLM-5"
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5"
        }
      }
    }
  }
}